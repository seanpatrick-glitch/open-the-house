rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Fetch the requesting user's Firestore document
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    // Is the requesting user a member of the given org?
    function isMember(orgId) {
      return isSignedIn() && orgId in userDoc().organizations;
    }

    // Is the requesting user an admin of the given org?
    function isAdmin(orgId) {
      return isMember(orgId) && userDoc().organizations[orgId].role == 'admin';
    }

    function isSecondaryAdmin(orgId) {
      return isMember(orgId) && userDoc().organizations[orgId].role == 'secondaryAdmin';
    }

    function isDepartmentHead(orgId) {
      return isMember(orgId) && userDoc().organizations[orgId].role == 'departmentHead';
    }

    function isAdminOrSecondary(orgId) {
      return isAdmin(orgId) || isSecondaryAdmin(orgId);
    }

    function isStaffLevel(orgId) {
      return isAdmin(orgId) || isSecondaryAdmin(orgId) || isDepartmentHead(orgId);
    }

    function isPerson(orgId) {
      return isMember(orgId) && userDoc().organizations[orgId].role == 'person';
    }

    // Is the requesting user an active Person class member?
    function isActivePerson(orgId) {
      let personDoc = get(/databases/$(database)/documents/organizations/$(orgId)/people/$(uid()));
      return personDoc != null
        && personDoc.data.status == 'active';
    }

    // Is the requesting user an active staff-toggled Person class member?
    function isActiveStaff(orgId) {
      let personDoc = get(/databases/$(database)/documents/organizations/$(orgId)/people/$(uid()));
      return personDoc != null
        && personDoc.data.status == 'active'
        && personDoc.data.staff == true;
    }

    // Is the requesting user in applied or waitlisted status?
    function isAppliedOrWaitlisted(orgId) {
      let personDoc = get(/databases/$(database)/documents/organizations/$(orgId)/people/$(uid()));
      return personDoc != null
        && (personDoc.data.status == 'applied' || personDoc.data.status == 'waitlisted');
    }

    // ── users ─────────────────────────────────────────────────────────────────
    // Any signed-in user can read any user doc (required for org member lookups
    // in CreateDepartmentForm and similar screens).
    // A user may write only their own doc; admins may write any user doc.
    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && uid() == userId;
      allow update: if isSignedIn() && uid() == userId;
    }

    // ── organizations ─────────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read:  if isMember(orgId);
      allow write: if isAdmin(orgId);
    }

    // ── departments ───────────────────────────────────────────────────────────
    match /departments/{departmentId} {
      allow read:           if isMember(resource.data.orgId);
      allow create:         if isAdmin(request.resource.data.orgId);
      allow update, delete: if isAdmin(resource.data.orgId);
    }

    // ── timelines ─────────────────────────────────────────────────────────────
    match /timelines/{timelineId} {
      allow read:           if isMember(resource.data.orgId);
      allow create:         if isAdmin(request.resource.data.orgId);
      allow update, delete: if isAdmin(resource.data.orgId);
    }

    // ── tasks + subcollections ────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read:           if isMember(resource.data.orgId);
      allow create:         if isAdmin(request.resource.data.orgId);
      allow update, delete: if isAdmin(resource.data.orgId);

      // comments — any org member can read/create; only author or admin can edit/delete
      match /comments/{commentId} {
        function taskOrgId() {
          return get(/databases/$(database)/documents/tasks/$(taskId)).data.orgId;
        }
        allow read, create: if isMember(taskOrgId());
        allow update:       if uid() == resource.data.createdBy;
        allow delete:       if uid() == resource.data.createdBy || isAdmin(taskOrgId());
      }

      // clarificationFlags — any org member can read/create; author or admin can update/delete
      match /clarificationFlags/{flagId} {
        function taskOrgId() {
          return get(/databases/$(database)/documents/tasks/$(taskId)).data.orgId;
        }
        allow read, create:   if isMember(taskOrgId());
        allow update, delete: if uid() == resource.data.createdBy || isAdmin(taskOrgId());
      }

      // accessRequests — any org member can read/create; only admins can approve/deny/delete
      match /accessRequests/{requestId} {
        function taskOrgId() {
          return get(/databases/$(database)/documents/tasks/$(taskId)).data.orgId;
        }
        allow read, create: if isMember(taskOrgId());
        allow update:       if isAdmin(taskOrgId());
        allow delete:       if isAdmin(taskOrgId());
      }
    }

    // ── timelineTemplates + subcollection ─────────────────────────────────────
    match /timelineTemplates/{templateId} {
      allow read:           if isMember(resource.data.orgId);
      allow create:         if isAdmin(request.resource.data.orgId);
      allow update, delete: if isAdmin(resource.data.orgId);

      match /templateTasks/{templateTaskId} {
        function templateOrgId() {
          return get(/databases/$(database)/documents/timelineTemplates/$(templateId)).data.orgId;
        }
        allow read:  if isMember(templateOrgId());
        allow write: if isAdmin(templateOrgId());
      }
    }

    // ── personTypes ───────────────────────────────────────────────────────────────
    match /organizations/{orgId}/personTypes/{typeId} {
      allow get:   if true;
      allow list:  if isStaffLevel(orgId);
      allow write: if isAdminOrSecondary(orgId);
    }

    // ── people + subcollections ───────────────────────────────────────────────────
    match /organizations/{orgId}/people/{personId} {
      // Admin and secondary admin: full access
      allow read, write: if isAdminOrSecondary(orgId);

      // Department Head: read all, write only their assigned type
      allow read:  if isDepartmentHead(orgId);
      allow write: if isDepartmentHead(orgId)
        && get(/databases/$(database)/documents/organizations/$(orgId)/personTypes/$(resource.data.typeId)).data.departmentHeadId == request.auth.uid;

      // Applied, waitlisted, active Person class: read own record only
      allow read: if (isAppliedOrWaitlisted(orgId) || isActivePerson(orgId) || isActiveStaff(orgId))
        && resource.data.accountUid == request.auth.uid;

      // Self-signup: allow create for applied records
      allow create: if request.resource.data.status == 'applied'
        && request.resource.data.createdBy == 'self-signup';

      // Account linking: allow update of accountUid and accountStatus only via token flow
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['accountUid', 'accountStatus'])
        && resource.data.accountUid == null;
    }

    match /organizations/{orgId}/people/{personId}/internalData/{docId} {
      allow read, write: if isStaffLevel(orgId);
    }

    match /organizations/{orgId}/people/{personId}/hours/{entryId} {
      allow read, write: if isStaffLevel(orgId);
      allow read:        if isActivePerson(orgId)
        && get(/databases/$(database)/documents/organizations/$(orgId)/people/$(personId)).data.accountUid == request.auth.uid;
    }

    // ── signupTokens ──────────────────────────────────────────────────────────────
    match /organizations/{orgId}/signupTokens/{tokenId} {
      allow read:  if resource.data.active == true;
      allow write: if isAdminOrSecondary(orgId);
    }

    // ── places + productions ──────────────────────────────────────────────────────
    match /organizations/{orgId}/places/{placeId} {
      allow read:           if isMember(orgId);
      allow create:         if isAdminOrSecondary(orgId);
      allow update, delete: if isAdminOrSecondary(orgId);

      match /productions/{productionId} {
        allow read:           if isMember(orgId);
        allow create:         if isAdminOrSecondary(orgId);
        allow update, delete: if isAdminOrSecondary(orgId);
      }
    }

    // ── collectionGroup query for productions ─────────────────────────────────────
    match /{path=**}/productions/{productionId} {
      allow read: if isMember(resource.data.orgId);
    }

    // ── invites ───────────────────────────────────────────────────────────────────
    match /organizations/{orgId}/invites/{inviteId} {
      allow get:            if true;
      allow list:           if isMember(orgId);
      allow create:         if isAdminOrSecondary(orgId);
      allow update:         if isAdminOrSecondary(orgId);
      allow delete:         if isAdminOrSecondary(orgId);
    }

    // ── collectionGroup query for invites (unauthenticated token lookup) ──────────
    match /{path=**}/invites/{inviteId} {
      allow get: if true;
    }

    // ── pendingInvites ────────────────────────────────────────────────────────────
    match /organizations/{orgId}/pendingInvites/{inviteId} {
      allow get:    if true;
      allow list:   if isAdminOrSecondary(orgId);
      allow create: if isAdminOrSecondary(orgId);
      allow update: if isAdminOrSecondary(orgId)
        || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow delete: if isAdminOrSecondary(orgId);
    }

    // ── personInviteTokens ────────────────────────────────────────────────────────
    match /organizations/{orgId}/personInviteTokens/{tokenId} {
      allow get:    if true;
      allow list:   if isStaffLevel(orgId);
      allow create: if isAdminOrSecondary(orgId);
      allow update: if isAdminOrSecondary(orgId)
        || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow delete: if isAdminOrSecondary(orgId);
    }

    // ── checkinTokens ─────────────────────────────────────────────────────────────
    match /organizations/{orgId}/checkinTokens/{tokenId} {
      allow get:    if true;
      allow list:   if isStaffLevel(orgId);
      allow write:  if isStaffLevel(orgId);
    }

    // ── checkins ──────────────────────────────────────────────────────────────────
    match /organizations/{orgId}/checkins/{checkinId} {
      // Staff: full read and write
      allow read, write: if isStaffLevel(orgId);

      // Active Person class: write own check-in only via valid token
      allow create: if isActivePerson(orgId)
        && request.resource.data.personId == request.auth.uid
        && request.resource.data.checkedInBy == 'self'
        && request.resource.data.tokenId != null
        && exists(/databases/$(database)/documents/organizations/$(orgId)/checkinTokens/$(request.resource.data.tokenId))
        && get(/databases/$(database)/documents/organizations/$(orgId)/checkinTokens/$(request.resource.data.tokenId)).data.active == true
        && get(/databases/$(database)/documents/organizations/$(orgId)/checkinTokens/$(request.resource.data.tokenId)).data.assignmentId == request.resource.data.assignmentId
        && request.time < get(/databases/$(database)/documents/organizations/$(orgId)/checkinTokens/$(request.resource.data.tokenId)).data.validUntil;

      // Active Person class: read own check-in history
      allow read: if isActivePerson(orgId)
        && resource.data.personId == request.auth.uid;
    }

  }
}
