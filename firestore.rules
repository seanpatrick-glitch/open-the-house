rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Fetch the requesting user's Firestore document
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    // Is the requesting user a member of the given org?
    function isMember(orgId) {
      return isSignedIn() && orgId in userDoc().organizations;
    }

    // Is the requesting user an admin of the given org?
    function isAdmin(orgId) {
      return isMember(orgId) && userDoc().organizations[orgId].role == 'admin';
    }

    function isSecondaryAdmin(orgId) {
      return isMember(orgId) && userDoc().organizations[orgId].role == 'secondaryAdmin';
    }

    function isDepartmentHead(orgId) {
      return isMember(orgId) && userDoc().organizations[orgId].role == 'departmentHead';
    }

    function isAdminOrSecondary(orgId) {
      return isAdmin(orgId) || isSecondaryAdmin(orgId);
    }

    function isStaffLevel(orgId) {
      return isAdmin(orgId) || isSecondaryAdmin(orgId) || isDepartmentHead(orgId);
    }

    function isPerson(orgId) {
      return isMember(orgId) && userDoc().organizations[orgId].role == 'person';
    }

    // ── users ─────────────────────────────────────────────────────────────────
    // Any signed-in user can read any user doc (required for org member lookups
    // in CreateDepartmentForm and similar screens).
    // A user may write only their own doc; admins may write any user doc.
    match /users/{userId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && uid() == userId;
    }

    // ── organizations ─────────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read:  if isMember(orgId);
      allow write: if isAdmin(orgId);
    }

    // ── departments ───────────────────────────────────────────────────────────
    match /departments/{departmentId} {
      allow read:           if isMember(resource.data.orgId);
      allow create:         if isAdmin(request.resource.data.orgId);
      allow update, delete: if isAdmin(resource.data.orgId);
    }

    // ── timelines ─────────────────────────────────────────────────────────────
    match /timelines/{timelineId} {
      allow read:           if isMember(resource.data.orgId);
      allow create:         if isAdmin(request.resource.data.orgId);
      allow update, delete: if isAdmin(resource.data.orgId);
    }

    // ── tasks + subcollections ────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read:           if isMember(resource.data.orgId);
      allow create:         if isAdmin(request.resource.data.orgId);
      allow update, delete: if isAdmin(resource.data.orgId);

      // comments — any org member can read/create; only author or admin can edit/delete
      match /comments/{commentId} {
        function taskOrgId() {
          return get(/databases/$(database)/documents/tasks/$(taskId)).data.orgId;
        }
        allow read, create: if isMember(taskOrgId());
        allow update:       if uid() == resource.data.createdBy;
        allow delete:       if uid() == resource.data.createdBy || isAdmin(taskOrgId());
      }

      // clarificationFlags — any org member can read/create; author or admin can update/delete
      match /clarificationFlags/{flagId} {
        function taskOrgId() {
          return get(/databases/$(database)/documents/tasks/$(taskId)).data.orgId;
        }
        allow read, create:   if isMember(taskOrgId());
        allow update, delete: if uid() == resource.data.createdBy || isAdmin(taskOrgId());
      }

      // accessRequests — any org member can read/create; only admins can approve/deny/delete
      match /accessRequests/{requestId} {
        function taskOrgId() {
          return get(/databases/$(database)/documents/tasks/$(taskId)).data.orgId;
        }
        allow read, create: if isMember(taskOrgId());
        allow update:       if isAdmin(taskOrgId());
        allow delete:       if isAdmin(taskOrgId());
      }
    }

    // ── timelineTemplates + subcollection ─────────────────────────────────────
    match /timelineTemplates/{templateId} {
      allow read:           if isMember(resource.data.orgId);
      allow create:         if isAdmin(request.resource.data.orgId);
      allow update, delete: if isAdmin(resource.data.orgId);

      match /templateTasks/{templateTaskId} {
        function templateOrgId() {
          return get(/databases/$(database)/documents/timelineTemplates/$(templateId)).data.orgId;
        }
        allow read:  if isMember(templateOrgId());
        allow write: if isAdmin(templateOrgId());
      }
    }

    // ── personTypes ───────────────────────────────────────────────────────────────
    match /organizations/{orgId}/personTypes/{typeId} {
      allow read:  if isStaffLevel(orgId);
      allow write: if isAdminOrSecondary(orgId);
    }

    // ── people + subcollections ───────────────────────────────────────────────────
    match /organizations/{orgId}/people/{personId} {
      allow read, write: if isAdminOrSecondary(orgId);
      allow read:        if isDepartmentHead(orgId);
      allow write:       if isDepartmentHead(orgId)
        && get(/databases/$(database)/documents/organizations/$(orgId)/personTypes/$(resource.data.typeId)).data.departmentHeadId == request.auth.uid;
      allow read:        if isPerson(orgId)
        && resource.data.uid == request.auth.uid;
      allow create:      if request.resource.data.status == 'pending'
        && request.resource.data.createdBy == 'self-signup';
    }

    match /organizations/{orgId}/people/{personId}/internalData/{docId} {
      allow read, write: if isStaffLevel(orgId);
    }

    match /organizations/{orgId}/people/{personId}/hours/{entryId} {
      allow read, write: if isStaffLevel(orgId);
      allow read:        if isPerson(orgId)
        && get(/databases/$(database)/documents/organizations/$(orgId)/people/$(personId)).data.uid == request.auth.uid;
    }

    // ── signupTokens ──────────────────────────────────────────────────────────────
    match /organizations/{orgId}/signupTokens/{tokenId} {
      allow read:  if resource.data.active == true;
      allow write: if isAdminOrSecondary(orgId);
    }

    // ── places + productions ──────────────────────────────────────────────────────
    match /organizations/{orgId}/places/{placeId} {
      allow read:           if isMember(orgId);
      allow create:         if isAdminOrSecondary(orgId);
      allow update, delete: if isAdminOrSecondary(orgId);

      match /productions/{productionId} {
        allow read:           if isMember(orgId);
        allow create:         if isAdminOrSecondary(orgId);
        allow update, delete: if isAdminOrSecondary(orgId);
      }
    }

    // ── collectionGroup query for productions ─────────────────────────────────────
    match /{path=**}/productions/{productionId} {
      allow read: if isMember(resource.data.orgId);
    }

  }
}
