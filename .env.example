# Copy this file to .env.local and fill in your Firebase values.
# NEVER commit .env.local to GitHub — it is already in .gitignore.

VITE_FIREBASE_API_KEY=paste-your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=paste-your-sender-id-here
VITE_FIREBASE_APP_ID=paste-your-app-id-here

# Google Calendar integration (see setup instructions in README or ask Claude)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
